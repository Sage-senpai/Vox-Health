# VoxHealth — environment variables
# Every integration ships with a working mock; setting a key flips that
# integration into "live" mode. Missing keys are not fatal.

# ─── ElevenLabs ─────────────────────────────────────────────
# Server-side. Used by /api/elevenlabs/token to mint signed agent tokens.
ELEVENLABS_API_KEY=
# The agent ID for the VoxHealth conversational agent (created in the EL dashboard).
ELEVENLABS_AGENT_ID=

# ─── NoahAI ────────────────────────────────────────────────
NOAH_API_KEY=
NOAH_API_BASE=https://api.trynoah.ai

# ─── Solana ────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# Anchor program id (filled in after `anchor deploy`)
NEXT_PUBLIC_VOXHEALTH_PROGRAM_ID=

# ─── Ledger ────────────────────────────────────────────────
# Ledger uses WebHID at runtime; no key required. This flag toggles the
# UI affordance — set to "true" once the device wiring is tested.
NEXT_PUBLIC_LEDGER_ENABLED=false

# ─── LI.FI ─────────────────────────────────────────────────
# Public widget integrator id. Optional — widget works without it.
NEXT_PUBLIC_LIFI_INTEGRATOR=voxhealth

# ─── Virtuals (caregiver agent) ────────────────────────────
VIRTUALS_AGENT_KEY=
# Where the on-prem caregiver runtime listens for our webhook.
VIRTUALS_WEBHOOK_URL=

# ─── Solana Mobile ─────────────────────────────────────────
# MWA only activates inside the Solana dApp Store browser; otherwise the
# app falls back to web wallet adapters. No key needed.
